<Window
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Пересохранение моделей"
    Height="650"
    Width="1100"
    WindowStartupLocation="CenterScreen"
    ResizeMode="CanResize"
    Background="#F3F3F3">

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DockPanel Margin="0,0,0,10">

            <Button
                x:Name="btn_select_models"
                Content="Выбрать модели"
                Width="160"
                Height="32"
                Margin="0,0,10,0"/>

            <Button
                x:Name="btn_fill_selected"
                Content="Заполнить путь для выбранных"
                Width="250"
                Height="32"
                Margin="0,0,10,0"/>

            <TextBlock
                VerticalAlignment="Center"
                Foreground="Gray"
                Text="Shift/Ctrl работают как в обычных таблицах"/>
        </DockPanel>

        <Border
            Grid.Row="1"
            BorderBrush="#999"
            BorderThickness="1"
            Background="White">

            <DataGrid
                x:Name="grid_models"
                AutoGenerateColumns="False"
                CanUserAddRows="False"
                SelectionMode="Extended"
                SelectionUnit="FullRow"
                HeadersVisibility="Column"
                GridLinesVisibility="Horizontal"
                RowHeaderWidth="0">

                <DataGrid.Columns>

                    <DataGridTemplateColumn Width="45">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <CheckBox
                                    IsChecked="{Binding Checked}"
                                    Click="checkbox_clicked"
                                    HorizontalAlignment="Center"
                                    VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTextColumn
                        Header="Имя модели"
                        Binding="{Binding ModelName}"
                        Width="280"
                        IsReadOnly="True"/>

                    <DataGridTemplateColumn Header="Папка сохранения на Revit Server" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBox
                                    Text="{Binding TargetFolder, UpdateSourceTrigger=PropertyChanged}"
                                    LostFocus="target_folder_lost_focus"
                                    Height="24"
                                    Padding="4,1,4,1"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                </DataGrid.Columns>
            </DataGrid>
        </Border>

        <DockPanel Grid.Row="2" Margin="0,10,0,0">

            <TextBlock
                x:Name="txt_status"
                VerticalAlignment="Center"
                Foreground="Gray"/>

            <Button
                x:Name="btn_save"
                Content="Сохранить модели"
                Width="180"
                Height="36"
                DockPanel.Dock="Right"
                IsEnabled="False"/>
        </DockPanel>
    </Grid>
</Window>